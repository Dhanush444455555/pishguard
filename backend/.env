# ── PhishGuard AI Environment Configuration ──────────────────────────────────
# Copy this to .env and adjust values for your environment.

# General
APP_ENV=development
DEBUG=true

# Security
SECRET_KEY=phishguard-dev-secret-key-change-in-production

# NeuralFlow Router (Intelligent AI Routing)
NEURALFLOW_PRIMARY_MODEL=phishguard-ensemble-v3
NEURALFLOW_FALLBACK_MODEL=phishguard-heuristic-v2
NEURALFLOW_FAST_TIMEOUT_MS=50
NEURALFLOW_STANDARD_TIMEOUT_MS=200
NEURALFLOW_DEEP_TIMEOUT_MS=1000

# Sentinel Memory Core (Persistent Threat Memory)
SENTINEL_DB_URL=sqlite:///./sentinel_memory.db
SENTINEL_VECTOR_DIM=64
SENTINEL_MAX_MEMORY=10000
SENTINEL_SIMILARITY_THRESHOLD=0.75

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Redis (optional — for production caching)
# REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_TTL=300

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/phishguard.log
LOG_JSON=false
